OPENAI_API_KEY=
OPENAI_RESPONSE_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=alloy

# 音乐搜索：cli / openapi / mock
MUSIC_PROVIDER=cli

NCM_CLI_BIN=ncm-cli
NCM_CLI_TIMEOUT_MS=12000
NCM_CLI_USE_MOCK=false
NCM_CLI_ALLOW_MOCK_FALLBACK=true
NCM_CLI_RESOLVE_STREAM_URL=true

# 仅当 MUSIC_PROVIDER=openapi 时使用（厂商入驻能力）
NETEASE_USE_MOCK=false
NETEASE_ALLOW_MOCK_FALLBACK=true
NETEASE_BASE_URL=https://developer.music.163.com/open-api
NETEASE_SEARCH_PATH=/api/song/search
NETEASE_DETAIL_PATH=/api/song/detail
NETEASE_APP_KEY=
NETEASE_APP_SECRET=
NETEASE_ACCESS_TOKEN=

# 天气（和风天气）
QWEATHER_API_HOST=https://devapi.qweather.com
QWEATHER_TOKEN=
QWEATHER_API_KEY=p34wcv9gqp.re.qweatherapi.com

# 大模型（DeepSeek）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# TTS（Fish Audio）
FISH_AUDIO_BASE_URL=https://api.fish.audio
FISH_AUDIO_API_KEY=
FISH_AUDIO_MODEL=s1
FISH_AUDIO_VOICE_ID=

# 播放代理可选白名单（逗号分隔域名），为空表示不限制
MUSIC_STREAM_PROXY_WHITELIST=
